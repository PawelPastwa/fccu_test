VAL_ 512 PURGE_VALVE 0 "CLOSED" 1 "OPEN";
VAL_ 512 FAN_STATE 0 "OFF" 1 "ON";
VAL_ 512 SYSTEM_ENABLED 0 "DISABLED" 1 "ENABLED";
VAL_ 530 SET_PURGE_MODE 0 "PERIODIC" 1 "VOLTAGE_THRESHOLD" 2 "MANUAL";
VAL_ 531 SET_FAN_MODE 0 "PROPORTIONAL" 1 "PID" 2 "MANUAL";
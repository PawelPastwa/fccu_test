VAL_ 256 MAIN_VALVE_ENABLED 0 "FALSE" 1 "TRUE";
VAL_ 256 MOTOR_CONTROLLER_ENABLED 0 "FALSE" 1 "TRUE";
VAL_ 257 SPEED_SENSOR_PULSE_RAW 0 "LOW" 1 "HIGH";
VAL_ 257 START_BUTTON 0 "RELEASED" 1 "PRESSED";

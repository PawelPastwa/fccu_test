VAL_ 257 RESET_BUTTON 0 "RELEASED" 1 "PRESSED";
VAL_ 257 CALIBRATION_BUTTON 0 "RELEASED" 1 "PRESSED";
VAL_ 257 LEAKAGE_DETECTED 0 "FALSE" 1 "TRUE";
VAL_ 257 SHELL_RELAY 0 "OFF" 1 "ON";
VAL_ 768 CAN_STATE 0 "ERROR_ACTIVE" 1 "ERROR_WARNING" 2 "ERROR_PASSIVE" 3 "BUS_OFF" 4 "STOPPED";

VAL_ 512 STATE 0 "INIT" 1 "IDLE" 2 "STARTING" 3 "RUNNING" 4 "ERROR";

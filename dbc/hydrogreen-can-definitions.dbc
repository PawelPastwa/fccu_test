CM_ BU_ CCU "CAN converter unit — bridges RS485 master data to CAN. Manages status LED and DFU.";
CM_ BU_ MCU "Master control unit (via CAN converter unit)";
CM_ BU_ SWU "Steering wheel unit";
CM_ BU_ LCU "Lighting control unit. Two identical boards (front/back) distinguished at runtime by a physical instance flag (switch or resistor).";
CM_ BU_ FCCU "Fuel cell control unit - will replace Spectronic Protium in future";
CM_ BU_ TCU "Telemetry control unit";
CM_ BU_ EDU "Electric drive unit";

CM_ BO_ 2147484672 "MCU authoritative lighting state, broadcast to both LCU instances. MCU derives state from SWU_LCU_INPUTS and brake pedal. LCU handles blink timing locally. Compliant with Article 50.";
CM_ SG_ 2147484672 HEADLIGHT "Front headlight(s). Art.50a.";
CM_ SG_ 2147484672 POSITION_LIGHT "Front and rear position/running lights. Art.50e.";
CM_ SG_ 2147484672 BRAKE_LIGHT "Rear red brake light(s), active when brake pedal pressed. Art.50d.";
CM_ SG_ 2147484672 LEFT_INDICATOR "Left turn indicator request. LCU handles blink timing. Art.50c.";
CM_ SG_ 2147484672 RIGHT_INDICATOR "Right turn indicator request. LCU handles blink timing. Art.50b.";
CM_ SG_ 2147484672 HAZARD "Hazard lights - overrides indicators, both sides blink. Art.50h.";
CM_ BO_ 2147484673 "LCU status. Both front and back instances transmit this frame. Signal layout mirrors MCU_LIGHTING for direct comparison. INSTANCE identifies which board sent it.";
CM_ SG_ 2147484673 INSTANCE "Physical instance flag set by onboard switch/resistor. 0=FRONT, 1=BACK.";
CM_ SG_ 2147484673 FAULT "LED strip or communication fault detected.";

CM_ BO_ 2147484416 "SWU cyclic status frame with CAN controller state and timing telemetry.";
CM_ SG_ 2147484416 CAN_STATE "Zephyr CAN controller state. 0=ERROR_ACTIVE, 1=ERROR_WARNING, 2=ERROR_PASSIVE, 3=BUS_OFF, 4=STOPPED.";
CM_ SG_ 2147484416 LAP_NUMBER "Current lap number, saturated to 255.";
CM_ SG_ 2147484416 LAP_TIME_MS "Current lap timer in milliseconds, saturated to 24 bits.";
CM_ SG_ 2147484416 TOTAL_TIME_MS "Total race/session timer in milliseconds, saturated to 24 bits.";
CM_ BO_ 2147484417 "SWU steering-wheel inputs mirrored with the MCU_INPUTS bit layout for consumers that use master-style controls.";
CM_ SG_ 2147484417 SPEED_SENSOR_PULSE_RAW "Raw speed sensor pulse input. Currently unused by SWU.";
CM_ SG_ 2147484417 START_BUTTON "Start button state.";
CM_ SG_ 2147484417 DEAD_MANS_SWITCH "Dead man's switch state.";
CM_ SG_ 2147484417 EMERGENCY_SWITCH "Emergency switch state.";
CM_ SG_ 2147484417 RESET_BUTTON "Reset button state.";
CM_ SG_ 2147484417 CALIBRATION_BUTTON "Calibration button state.";
CM_ SG_ 2147484417 LEAKAGE_DETECTED "Leakage sensor switch state.";
CM_ SG_ 2147484417 SHELL_RELAY "Shell telemetry emergency relay input.";
CM_ BO_ 2147484418 "SWU lighting-control button inputs for LCU/lighting consumers.";
CM_ SG_ 2147484418 HAZARD "Hazard lights button.";
CM_ SG_ 2147484418 BEAM "High beam button.";
CM_ SG_ 2147484418 POSITION "Position lights button.";
CM_ SG_ 2147484418 RIGHT_INDICATOR "Right turn indicator button.";
CM_ SG_ 2147484418 LEFT_INDICATOR "Left turn indicator button.";
CM_ SG_ 2147484418 BRAKE_LIGHT "Brake light request.";

CM_ SG_ 2147483906 SPEED_SENSOR_PULSE_RAW "Raw speed sensor pulse input (currently expected false in SCADE input mapping).";

CM_ BO_ 2147483913 "MCU SCADE acceleration and recuperation output voltages.";
CM_ SG_ 2147483913 ACCELERATION_OUTPUT_VOLTAGE "SCADE acceleration output voltage.";
CM_ SG_ 2147483913 BRAKE_OUTPUT_VOLTAGE "SCADE recuperation/brake output voltage.";

CM_ SG_ 2147483912 AI1 "Unassigned analog input AI1 (J3 pin not listed in hardware doc). Purpose TBD.";
CM_ SG_ 2147483912 AI3 "Unassigned analog input AI3 (J3 pin not listed in hardware doc). Purpose TBD.";
CM_ SG_ 2147483912 AI4 "Unassigned analog input AI4 (J3 pin not listed in hardware doc). Purpose TBD.";
CM_ SG_ 2147483912 AI5 "Unassigned analog input AI5 (J3 pin not listed in hardware doc). Purpose TBD.";

CM_ BO_ 2147484160 "Spectronic Protium data forwarded by MCU via RS485. Scheduled for removal when FCCU replaces Protium.";
CM_ SG_ 2147484161 FAN "Cooling fan duty cycle.";
CM_ SG_ 2147484161 BLW "Cathode air blower duty cycle - feeds oxygen to the fuel cell stack.";
CM_ SG_ 2147484163 V_SET "Fuel cell output voltage setpoint.";
CM_ SG_ 2147484163 I_SET "Fuel cell output current setpoint.";
CM_ SG_ 2147484163 UCB_V "Unit cell balancer voltage - Spectronic internal reference.";
CM_ SG_ 2147484165 IP "Internal pressure - Spectronic cryptic naming, verify against Protium docs.";
CM_ SG_ 2147484165 TP "Temperature probe - Spectronic cryptic naming, verify against Protium docs.";

